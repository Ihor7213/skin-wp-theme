{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "artonskin/specialist-card",
  "version": "1.1.0",
  "title": "Specialist Card",
  "category": "widgets",
  "icon": "id-alt",
  "description": "Artist/specialist card with photo, name, role, bio and CTA button.",
  "textdomain": "artonskin",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css",
  "attributes": {
    "name": {
      "type": "string",
      "default": ""
    },
    "role": {
      "type": "string",
      "default": ""
    },
    "years": {
      "type": "string",
      "default": ""
    },
    "bio": {
      "type": "string",
      "default": ""
    },
    "ctaText": {
      "type": "string",
      "default": "Book a session"
    },
    "ctaUrl": {
      "type": "string",
      "default": "#contact"
    },
    "photoUrl": {
      "type": "string",
      "default": ""
    },
    "photoAlt": {
      "type": "string",
      "default": ""
    }
  }
}
